{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sqmch/coursesmith/docs/schema/progress.schema.json",
  "title": "tutor/progress.json",
  "description": "Learner profile, current module, and per-module status/hint/attempt records. See docs/FORMAT.md.",
  "type": "object",
  "required": ["learner", "currentModule", "modules"],
  "properties": {
    "learner": {
      "type": "object",
      "required": ["profile", "paceHoursPerWeek", "started"],
      "properties": {
        "profile": { "type": "string" },
        "paceHoursPerWeek": {
          "type": "string",
          "$comment": "A range string like '3-5', not a number."
        },
        "started": {
          "type": "string",
          "$comment": "ISO date once onboarded, but the template seeds it empty — so string, no date pattern."
        }
      },
      "additionalProperties": true
    },
    "currentModule": {
      "type": ["string", "null"],
      "$comment": "null before the first module exists (the template's value)."
    },
    "modules": {
      "type": "object",
      "$comment": "Keyed by module id; every value is a module-progress record.",
      "additionalProperties": {
        "type": "object",
        "required": ["status"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["not-started", "in-progress", "completed"],
            "$comment": "Canonical on-disk vocabulary. The study normalizes 'completed' -> 'complete' for the UI only."
          },
          "startedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "completedAt": {
            "type": ["string", "null"],
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "$comment": "null while in-progress."
          },
          "hintsUsed": {
            "type": "array",
            "items": { "type": "string" }
          },
          "checkAttempts": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" },
          "bossCheck": {
            "type": "object",
            "$comment": "Optional per-module phase-gate record. Distinct from module.json's boolean bossCheck (which only flags that a module ends a phase): this is the auditable trace of attempts. Every attempt is logged, pass or fail — CLAUDE.md Boundaries.",
            "required": ["passedAt", "attempts"],
            "properties": {
              "passedAt": {
                "type": ["string", "null"],
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "$comment": "ISO date the gate was genuinely passed; null while still failing."
              },
              "attempts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["date", "outcome"],
                  "properties": {
                    "date": {
                      "type": "string",
                      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                    },
                    "outcome": {
                      "type": "string",
                      "enum": ["passed", "failed"]
                    },
                    "notes": { "type": "string" }
                  },
                  "additionalProperties": true
                }
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
