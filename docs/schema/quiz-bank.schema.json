{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/sqmch/coursesmith/docs/schema/quiz-bank.schema.json",
  "title": "tutor/quiz-bank.json",
  "description": "Spaced-repetition items. scripts/quiz.mjs is the writer of record for interval, due, and history. See docs/FORMAT.md.",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module", "question", "interval", "due", "history"],
        "properties": {
          "id": {
            "type": "string",
            "$comment": "module prefix + slug; ids must be unique (quiz.mjs enforces on seed)."
          },
          "module": { "type": "string" },
          "question": { "type": "string" },
          "interval": {
            "type": "integer",
            "minimum": 1,
            "$comment": "Whole days. quiz.mjs: correct -> max(2, round(prev*2.5)); partial -> 2; wrong/tutored/seed -> 1."
          },
          "due": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
            "$comment": "ISO date; due when today >= due."
          },
          "history": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["date", "result"],
              "properties": {
                "date": {
                  "type": "string",
                  "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
                },
                "result": {
                  "type": "string",
                  "enum": ["correct", "partial", "wrong", "tutored", "rescheduled"],
                  "$comment": "Grades: correct|partial|wrong|tutored. 'rescheduled' is bookkeeping, never a grade (entry exists only for items actually touched)."
                },
                "note": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
